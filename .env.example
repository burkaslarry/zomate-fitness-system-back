# Copy to .env and fill in.
#
# PostgreSQL（eventxp / EventXP）：Render Dashboard → PostgreSQL → External Database URL，
# 貼到下方。所有業務表皆為 zomate_fs_*（見 app/models.py）。

# Primary connection (SQLAlchemy → zomate_fs_*)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Optional: force SSL for non-Render URLs
# DATABASE_SSL=1
# DATABASE_SSLMODE=require

# CORS: comma-separated origins for Next.js front (production + local)
FRONTEND_ORIGIN=http://localhost:3000,https://zomate-fitness-system-front.vercel.app

# File uploads: photos/receipts are stored under {kind}/{hkid}/{timestamp}-{filename}
UPLOADS_DIR=./uploads

# Active member badge: check-ins within this many days
ACTIVE_MEMBER_DAYS=30

# Fail startup if DATABASE_URL is missing from the environment (CI / strict dev)
# STRICT_DATABASE_URL=1

# Public URL for Render keepalive self-ping (no trailing slash required)
# PUBLIC_BASE_URL=https://zomate-fitness-system-back.onrender.com
# KEEPALIVE_ENABLED=false
# KEEPALIVE_INTERVAL_SECONDS=600
# KEEPALIVE_TIMEOUT_SECONDS=5
# KEEPALIVE_JITTER_SECONDS=30

# Optional stable instance id in logs / health
# INSTANCE_ID=render-instance-1

# Structured log level
# LOG_LEVEL=INFO

# Deterministic OTP for `/api/register/*` smoke tests (otherwise random 6-digit)
# REGISTER_OTP_MOCK_CODE=999999

# ---------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API) — proactive reminders
# Full setup checklist: docs/WHATSAPP_BUSINESS_API_TODO.md
# ---------------------------------------------------------------------------

# Set true only after Meta templates are approved and credentials below are filled.
# WHATSAPP_ENABLED=false

# Permanent token from Meta App Dashboard → WhatsApp → API Setup
# WHATSAPP_ACCESS_TOKEN=

# Phone number ID from Meta WhatsApp Manager (NOT the display phone number)
# WHATSAPP_PHONE_NUMBER_ID=

# Canonical WABA (+852 6052 9291): 196479503537635
# WHATSAPP_BUSINESS_ACCOUNT_ID=196479503537635
# WHATSAPP_PHONE_NUMBER_ID=127908193750328
# WHATSAPP_APP_ID=1866225351411888

# Default template language code (Meta locale, e.g. zh_HK, en_US)
# WHATSAPP_DEFAULT_LANGUAGE=zh_HK

# Map internal template keys → Meta-approved template names + body variable order.
# Each Meta template body must use {{1}}, {{2}}, … in the same order as body_params.
# WHATSAPP_TEMPLATE_MAP={"payment_student_pending":{"name":"zomate_payment_pending","language":"zh_HK","body_params":["course_title","student_name","student_phone","pin","next_lesson_date","lessons_attended","lessons_remaining"]},"payment_student_installment":{"name":"zomate_payment_installment","language":"zh_HK","body_params":["course_title","student_name","student_phone","pin","next_lesson_date","lessons_attended","lessons_remaining","payment_status","amount_paid","total_amount","amount_owing","installment_notes"]},"payment_student_full":{"name":"zomate_payment_full","language":"zh_HK","body_params":["course_title","student_name","student_phone","pin","next_lesson_date","lessons_attended","lessons_remaining","payment_status","amount_paid","total_amount"]},"payment_coach":{"name":"zomate_payment_coach","language":"zh_HK","body_params":["course_title","student_name","student_phone","next_lesson_date","lessons_attended","lessons_remaining","payment_status","amount_paid","total_amount","amount_owing","installment_notes"]}}

# Webhook verify token for Meta WhatsApp callback setup:
# Callback URL: https://<your-backend>/api/webhooks/whatsapp
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=zomate_wh_verify_2026
