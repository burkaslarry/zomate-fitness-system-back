# Copy to .env and fill in.
#
# PostgreSQL（eventxp / EventXP）：Render Dashboard → PostgreSQL → External Database URL，
# 貼到下方。所有業務表皆為 zomate_fs_*（見 app/models.py）。

# Primary connection (SQLAlchemy → zomate_fs_*)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Optional: force SSL for non-Render URLs
# DATABASE_SSL=1
# DATABASE_SSLMODE=require

# CORS: comma-separated origins for Next.js front (production + local)
FRONTEND_ORIGIN=http://localhost:3000,https://zomate-fitness-system-front.vercel.app

# File uploads: photos/receipts are stored under {kind}/{hkid}/{timestamp}-{filename}
UPLOADS_DIR=./uploads

# Active member badge: check-ins within this many days
ACTIVE_MEMBER_DAYS=30
